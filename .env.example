# AeroOps local development configuration
# Copy to .env. Never commit .env or real credentials.

# Public/offline demonstration mode. No Gemini, ADK Runner, MCP subprocess,
# or SQLite access occurs while this is enabled.
AEROOPS_OFFLINE_DEMO=1

# ADK model identifier used only by the live path.
AEROOPS_MODEL=gemini-2.5-flash

# Bounded live-model resilience.  Defaults are suitable for local and
# Streamlit Community Cloud deployments.
AEROOPS_MODEL_REQUEST_TIMEOUT_MS=120000
AEROOPS_MODEL_RETRY_ATTEMPTS=4
AEROOPS_MODEL_RETRY_INITIAL_DELAY_SECONDS=1.0
AEROOPS_MODEL_RETRY_MAX_DELAY_SECONDS=8.0

# Synthetic SQLite artifact used by the live MCP-backed path.
AEROOPS_DB_PATH=data/aeroops.db

# Optional live Gemini credential. Leave empty for offline mode.
GOOGLE_API_KEY=
